NODE_ENV=development
PORT=13000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_platform
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:13001,http://localhost:13002,http://localhost:13003,http://localhost:13004,http://localhost:13005,http://localhost:13006,http://localhost:13007,http://localhost:13008,http://localhost:13009,http://localhost:13010

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
MAX_WORKSPACE_STORAGE=524288000
