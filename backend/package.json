{
  "name": "@crm-platform/backend",
  "version": "1.0.0",
  "description": "CRM Platform Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "migrate": "sequelize db:migrate",
    "reset:e2e": "ts-node src/scripts/reset-e2e.ts",
    "seed": "ts-node src/seeds/index.ts",
    "seed:novapay": "ts-node src/seeds/novapay/index.ts",
    "seed:medvista": "ts-node src/seeds/medvista/index.ts",
    "seed:trustguard": "ts-node src/seeds/trustguard/index.ts",
    "seed:urbannest": "ts-node src/seeds/urbannest/index.ts",
    "seed:swiftroute": "ts-node src/seeds/swiftroute/index.ts",
    "seed:dentaflow": "ts-node src/seeds/dentaflow/index.ts",
    "seed:jurispath": "ts-node src/seeds/jurispath/index.ts",
    "seed:tablesync": "ts-node src/seeds/tablesync/index.ts",
    "seed:cranestack": "ts-node src/seeds/cranestack/index.ts",
    "seed:edupulse": "ts-node src/seeds/edupulse/index.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.4",
    "socket.io": "^4.8.0",
    "umzug": "^3.8.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.4",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
